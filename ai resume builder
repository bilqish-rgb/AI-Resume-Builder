/* ============ HELPERS ============ */
function esc(str){
  if(!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function nl2br(str){
  return esc(str).replace(/\n/g,'<br>');
}
function fmtRange(start,end,current){
  const s = start || '—';
  const e = current ? 'Sekarang' : (end || '—');
  return `${s} – ${e}`;
}
function getInitials(name){
  const parts = (name || '').trim().split(/\s+/).filter(Boolean);
  if(!parts.length) return 'NN';
  if(parts.length===1) return parts[0].slice(0,2).toUpperCase();
  return (parts[0][0] + parts[parts.length-1][0]).toUpperCase();
}
function themeVarsStyle(theme){
  let s = `--r-accent:${theme.accent||'#B4802B'};--r-ink:${theme.ink||'#14213D'};--r-soft:${theme.soft||'#F0EFE7'};--r-font-display:${theme.fontDisplay||F_INTER};--r-font-body:${theme.fontBody||F_INTER};`;
  if(theme.accentB) s += `--r-accent-b:${theme.accentB};`;
  return s;
}
function currentTemplate(){
  return TEMPLATES.find(t => t.id === state.template) || TEMPLATES[0];
}

/* ============ AI IMPROVE ============ */
async function aiImprove(text, context){
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({
      model: 'claude-sonnet-4-6',
      max_tokens: 800,
      system: `Kamu adalah editor CV profesional berbahasa Indonesia. Perbaiki teks yang diberikan (bagian: ${context}) agar: lebih ringkas, memakai kata kerja aktif berorientasi hasil, terdengar profesional, dan bebas typo/ejaan. Jangan menambahkan fakta, angka, atau pencapaian baru yang tidak disebutkan pengguna. Pertahankan bahasa Indonesia. Balas HANYA dengan teks hasil akhir, tanpa tanda kutip, tanpa penjelasan, tanpa markdown.`,
      messages: [{role:'user', content: text}]
    })
  });
  if(!res.ok) throw new Error('API error ' + res.status);
  const data = await res.json();
  const out = (data.content || []).map(b => b.text || '').join('').trim();
  return out;
}

async function handleAiClick(btn){
  const targetSel = btn.getAttribute('data-target');
  const el = document.querySelector(targetSel);
  if(!el) return;
  const text = el.value.trim();
  if(!text){
    alert('Isi teks terlebih dahulu sebelum menggunakan AI.');
    return;
  }
  const context = btn.getAttribute('data-context') || 'teks CV';
  const original = btn.textContent;
  btn.disabled = true;
  btn.textContent = 'Menyempurnakan…';
  try{
    const improved = await aiImprove(text, context);
    if(improved){
      el.value = improved;
      el.dispatchEvent(new Event('input', {bubbles:true}));
    }
  }catch(err){
    console.error(err);
    alert('Gagal menghubungi AI. Silakan coba lagi.');
  }finally{
    btn.disabled = false;
    btn.textContent = original;
  }
}

