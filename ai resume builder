/* ============ RENDER: PREVIEW ============ */
function renderPreview(){
  const inner = document.getElementById('previewInner');
  inner.innerHTML = buildResumeHTML();
  document.getElementById('templateLabel').textContent = 'Template: ' + currentTemplate().name;
  fitScale();
}

function skillPillsHTML(){
  if(!state.skills.length) return '<p class="empty-note">Belum ada skill ditambahkan.</p>';
  return state.skills.map(s => `<span class="skill-pill">${esc(s)}</span>`).join('');
}
function languagesHTML(dark){
  if(!state.languages.length) return `<p class="empty-note" style="${dark?'color:#9AA1B8;':''}">—</p>`;
  return state.languages.map(l => `<div class="${dark?'skill-pill':'item'}" ${dark?'':'style="margin-bottom:6px;"'}>${dark?esc(l.name)+' · '+esc(l.level):`<span style="font-weight:600;">${esc(l.name)}</span> <span style="color:#666;">— ${esc(l.level)}</span>`}</div>`).join('');
}
function experienceHTML(){
  if(!state.experience.length) return '<p class="empty-note">Belum ada pengalaman ditambahkan.</p>';
  return state.experience.map(it => `
    <div class="item">
      <div class="item-head">
