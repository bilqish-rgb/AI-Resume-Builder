<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Resume Builder</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
:root{
  --ink:#14213D;
  --ink-2:#1D2B4F;
  --paper:#F1F2EE;
  --panel:#FFFFFF;
  --brass:#B4802B;
  --brass-dark:#8C6220;
  --sage:#5F7161;
  --line:#DEDDD3;
  --text:#1D2333;
  --text-soft:#5B6072;
  --danger:#B3423E;
  --radius:10px;
  --shadow:0 1px 2px rgba(20,33,61,0.06);
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  font-family:'Inter',system-ui,sans-serif;
  background:var(--paper);
  color:var(--text);
  min-height:100vh;
}
.app{
  display:flex;
  flex-direction:column;
  min-height:100vh;
}

/* ---------- TOPBAR ---------- */
.topbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:14px 28px;
  background:var(--ink);
  color:#fff;
}
.brand{
  display:flex;
  align-items:center;
  gap:10px;
}
.brand-mark{
  width:34px;height:34px;
  border-radius:50%;
  border:1.5px solid var(--brass);
  display:flex;align-items:center;justify-content:center;
  font-family:'Fraunces',serif;
  font-weight:600;
  font-size:15px;
  color:var(--brass);
  flex-shrink:0;
}
.brand-text h1{
  font-family:'Fraunces',serif;
  font-size:18px;
  font-weight:600;
  margin:0;
  letter-spacing:0.2px;
}
.brand-text span{
  font-size:11px;
  color:#B9C0D4;
  letter-spacing:0.5px;
}
.topbar-actions{display:flex;gap:10px;align-items:center;}
.btn{
  font-family:'Inter',sans-serif;
  font-size:13px;
  font-weight:600;
  border-radius:8px;
  border:1px solid transparent;
  padding:9px 16px;
  cursor:pointer;
  display:inline-flex;
  align-items:center;
  gap:7px;
  transition:transform .12s ease, background .15s ease, opacity .15s;
  white-space:nowrap;
}
.btn:active{transform:scale(0.97);}
.btn-brass{
  background:var(--brass);
  color:#fff;
}
.btn-brass:hover{background:var(--brass-dark);}
.btn-ghost-dark{
  background:transparent;
  border-color:rgba(255,255,255,0.28);
  color:#fff;
}
.btn-ghost-dark:hover{background:rgba(255,255,255,0.08);}
.btn-outline{
  background:#fff;
  border-color:var(--line);
  color:var(--ink);
}
.btn-outline:hover{border-color:var(--brass);color:var(--brass-dark);}
.btn-mini{
  font-size:11.5px;
  padding:5px 10px;
  border-radius:6px;
  background:#F1EADC;
  border:1px solid #E4D6B8;
  color:var(--brass-dark);
  font-weight:600;
  cursor:pointer;
}
.btn-mini:hover{background:#E9DEC2;}
.btn-mini:disabled{opacity:.55;cursor:default;}
.btn:disabled{opacity:.6;cursor:default;}

/* ---------- LAYOUT ---------- */
.layout{
  flex:1;
  display:grid;
  grid-template-columns:minmax(340px,440px) 1fr;
  gap:0;
  align-items:start;
}
.panel-left{
  padding:22px 24px 60px;
  border-right:1px solid var(--line);
  background:var(--paper);
}
.panel-right{
  padding:28px 34px 60px;
  display:flex;
  flex-direction:column;
  align-items:center;
  min-height:calc(100vh - 63px);
}

/* ---------- TABS ---------- */
.tabs{
  display:flex;
  gap:6px;
  margin-bottom:20px;
  flex-wrap:wrap;
}
.tab-btn{
  font-family:'Inter',sans-serif;
  font-size:12.5px;
  font-weight:600;
  padding:8px 12px;
  border-radius:20px;
  border:1px solid var(--line);
  background:#fff;
  color:var(--text-soft);
  cursor:pointer;
}
.tab-btn.active{
  background:var(--ink);
  border-color:var(--ink);
  color:#fff;
}
.tab-btn:hover:not(.active){border-color:var(--brass);color:var(--brass-dark);}

.form-section h2{
  font-family:'Fraunces',serif;
  font-size:16px;
  font-weight:600;
  margin:0 0 4px;
  color:var(--ink);
}
.form-section .hint{
  font-size:12px;
  color:var(--text-soft);
  margin:0 0 16px;
}
.field{
  margin-bottom:13px;
}
.field label{
  display:block;
  font-size:11.5px;
  font-weight:600;
  color:var(--text-soft);
  margin-bottom:5px;
  letter-spacing:0.2px;
}
.field-row{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}
input[type=text],input[type=email],input[type=tel],textarea,select{
  width:100%;
  font-family:'Inter',sans-serif;
  font-size:13.5px;
  padding:9px 11px;
  border-radius:8px;
  border:1px solid var(--line);
  background:#fff;
  color:var(--text);
  outline:none;
}
textarea{resize:vertical;min-height:74px;line-height:1.5;}
input:focus,textarea:focus,select:focus{border-color:var(--brass);box-shadow:0 0 0 3px rgba(180,128,43,0.12);}
.field-foot{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-top:6px;
}

.card-item{
  background:#fff;
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:14px 14px 6px;
  margin-bottom:14px;
  position:relative;
}
.card-item-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:10px;
}
.card-item-head span{
  font-size:11px;
  font-weight:700;
  letter-spacing:0.6px;
  text-transform:uppercase;
  color:var(--brass-dark);
}
.remove-btn{
  border:none;background:none;color:#9B9C8F;cursor:pointer;font-size:16px;line-height:1;padding:2px 4px;
}
.remove-btn:hover{color:var(--danger);}
.add-btn{
  width:100%;
  padding:10px;
  border-radius:8px;
  border:1.5px dashed #C7C2AE;
  background:transparent;
  color:var(--text-soft);
  font-size:13px;
  font-weight:600;
  cursor:pointer;
  margin-top:2px;
}
.add-btn:hover{border-color:var(--brass);color:var(--brass-dark);}
.checkbox-line{
  display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--text-soft);margin:2px 0 12px;
}

/* skills / tags */
.tag-input-row{display:flex;gap:8px;margin-bottom:10px;}
.tag-input-row input{flex:1;}
.tags{display:flex;flex-wrap:wrap;gap:7px;}
.tag{
  background:#EDEAD8;
  border:1px solid #DCD5B8;
  color:var(--ink-2);
  font-size:12.5px;
  font-weight:500;
  padding:5px 8px 5px 11px;
  border-radius:16px;
  display:flex;align-items:center;gap:6px;
}
.tag button{border:none;background:none;color:#8B8570;cursor:pointer;font-size:14px;line-height:1;}
.tag button:hover{color:var(--danger);}

/* ---------- TEMPLATE GALLERY ---------- */
.tpl-group-title{
  font-size:11px;
  font-weight:700;
  letter-spacing:1px;
  text-transform:uppercase;
  color:var(--text-soft);
  margin:18px 0 10px;
}
.tpl-group-title:first-of-type{margin-top:0;}
.tpl-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
}
.tpl-card{
  background:#fff;
  border:2px solid var(--line);
  border-radius:12px;
  padding:10px;
  cursor:pointer;
  text-align:left;
}
.tpl-card.selected{border-color:var(--brass);box-shadow:0 0 0 3px rgba(180,128,43,0.12);}
.tpl-thumb{
  height:96px;
  border-radius:6px;
  margin-bottom:9px;
  overflow:hidden;
  border:1px solid var(--line);
  display:flex;
}
.tpl-name{font-size:12.5px;font-weight:700;color:var(--ink);}
.tpl-desc{font-size:11px;color:var(--text-soft);margin-top:2px;}

/* mini thumb structures */
.thumb-modern{width:100%;background:#fff;padding:8px;}
.thumb-modern .l1{height:8px;width:60%;border-radius:2px;margin-bottom:4px;}
.thumb-modern .l2{height:4px;width:40%;border-radius:2px;margin-bottom:8px;}
.thumb-modern .l3{height:3px;width:90%;background:#E3E2DA;border-radius:2px;margin-bottom:3px;}
.thumb-modern .l3b{height:3px;width:75%;background:#E3E2DA;border-radius:2px;}

.thumb-elegant{width:100%;background:#fff;padding:8px;text-align:center;}
.thumb-elegant .l1{height:8px;width:55%;border-radius:2px;margin:0 auto 4px;}
.thumb-elegant .rule{height:1px;width:70%;margin:0 auto 8px;}
.thumb-elegant .l3{height:3px;width:80%;background:#E3E2DA;border-radius:2px;margin:0 auto 3px;}
.thumb-elegant .l3b{height:3px;width:65%;background:#E3E2DA;border-radius:2px;margin:0 auto;}

.thumb-sidebar{width:100%;display:flex;}
.thumb-sidebar .side{width:34%;}
.thumb-sidebar .main{flex:1;background:#fff;padding:8px;}
.thumb-sidebar .main .l1{height:6px;width:70%;background:#DADADA;border-radius:2px;margin-bottom:6px;}
.thumb-sidebar .main .l3{height:3px;width:90%;background:#E3E2DA;border-radius:2px;margin-bottom:3px;}
.thumb-sidebar .main .l3b{height:3px;width:60%;background:#E3E2DA;border-radius:2px;}

.thumb-creative{width:100%;background:#fff;}
.thumb-creative .band{height:30px;}
.thumb-creative .body{padding:8px;}
.thumb-creative .l3{height:3px;width:85%;background:#E3E2DA;border-radius:2px;margin-bottom:3px;}
.thumb-creative .pill{display:inline-block;height:10px;width:22px;border-radius:6px;margin:6px 3px 0 0;}

.thumb-ats{width:100%;background:#fff;padding:8px;}
.thumb-ats .l1{height:7px;width:50%;background:#222;border-radius:1px;margin-bottom:6px;}
.thumb-ats .l3{height:3px;width:92%;background:#E3E2DA;margin-bottom:3px;}
.thumb-ats .l3b{height:3px;width:80%;background:#E3E2DA;}

.thumb-timeline{width:100%;padding:8px;background:#fff;}
.thumb-timeline .tl-head{height:8px;width:50%;border-radius:2px;margin-bottom:10px;}
.thumb-timeline .tl-item{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
.thumb-timeline .tl-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.thumb-timeline .tl-line{height:3px;flex:1;background:#E3E2DA;border-radius:2px;}

.thumb-compact{width:100%;background:#fff;}
.thumb-compact .cp-head{display:flex;align-items:center;gap:6px;padding:8px 8px 6px;}
.thumb-compact .cp-avatar{width:16px;height:16px;border-radius:50%;display:inline-block;flex-shrink:0;}
.thumb-compact .cp-lines{flex:1;}
.thumb-compact .cp-lines .l1{height:6px;width:70%;border-radius:2px;margin-bottom:4px;}
.thumb-compact .cp-lines .l2b{height:3px;width:50%;background:#E3E2DA;border-radius:2px;}
.thumb-compact .cp-body{display:flex;gap:4px;padding:0 8px 8px;}
.thumb-compact .cp-main{flex:1;height:40px;background:#F5F4EE;border-radius:3px;}
.thumb-compact .cp-aside{width:26%;height:40px;border-radius:3px;}

.ats-badge{
  display:inline-block;margin-top:6px;font-size:10px;font-weight:700;color:var(--sage);
  background:#E7EEE7;padding:2px 7px;border-radius:5px;
}

/* ---------- PREVIEW ---------- */
.preview-toolbar{
  width:100%;
  max-width:794px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:16px;
}
.preview-toolbar .zoom-label{font-size:12px;color:var(--text-soft);}
.stamp{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:11px;
  font-weight:700;
  color:var(--sage);
  border:1px solid #C9D6C9;
  background:#EEF3EC;
  padding:5px 10px;
  border-radius:20px;
}
.stamp i{
  width:6px;height:6px;border-radius:50%;background:var(--sage);display:inline-block;
}

.preview-stage{
  width:100%;
  display:flex;
  justify-content:center;
  overflow:hidden;
}
.preview-scaler{
  transform-origin:top center;
}
#previewInner{
  width:794px;
  min-height:1123px;
  background:#fff;
  box-shadow:0 4px 24px rgba(20,33,61,0.14);
}

/* ===== RESUME BASE ===== */
.resume{
  width:794px;min-height:1123px;color:#1a1a1a;
  --r-accent:#B4802B;
  --r-ink:#14213D;
  --r-soft:#F0EFE7;
  --r-font-display:'Inter',sans-serif;
  --r-font-body:'Inter',sans-serif;
}
.resume h1,.resume h2,.resume h3,.resume p,.resume ul,.resume li{margin:0;padding:0;}
.resume .sec{margin-bottom:18px;}
.resume .sec-title{
  font-size:12.5px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  margin-bottom:10px;
}
.resume .item{margin-bottom:12px;}
.resume .item-head{display:flex;justify-content:space-between;align-items:baseline;gap:10px;}
.resume .item-role{font-weight:700;font-size:13.5px;}
.resume .item-sub{font-size:12px;color:#555;}
.resume .item-date{font-size:11px;color:#666;white-space:nowrap;}
.resume .item-desc{font-size:12px;line-height:1.55;color:#333;margin-top:4px;white-space:pre-line;}
.resume .empty-note{color:#999;font-style:italic;}

/* MODERN */
.tpl-modern{padding:46px 50px;font-family:var(--r-font-body);}
.tpl-modern .r-name{font-size:29px;font-weight:700;color:var(--r-ink);letter-spacing:-0.3px;font-family:var(--r-font-display);}
.tpl-modern .r-title{font-size:14px;color:var(--r-accent);font-weight:600;margin-top:3px;}
.tpl-modern .r-contact{display:flex;flex-wrap:wrap;gap:12px;font-size:11.5px;color:#555;margin-top:10px;}
.tpl-modern .r-head{border-bottom:2.5px solid var(--r-ink);padding-bottom:16px;margin-bottom:22px;}
.tpl-modern .sec-title{color:var(--r-ink);border-left:3px solid var(--r-accent);padding-left:8px;}
.tpl-modern .skill-pill{display:inline-block;background:var(--r-soft);color:var(--r-ink);font-size:11.5px;font-weight:600;padding:5px 11px;border-radius:5px;margin:0 6px 6px 0;}

/* ELEGANT */
.tpl-elegant{padding:50px 60px;font-family:var(--r-font-display);text-align:center;}
.tpl-elegant .r-name{font-size:32px;font-weight:600;letter-spacing:0.5px;color:var(--r-ink);}
.tpl-elegant .r-title{font-size:13px;color:var(--r-accent);letter-spacing:1.5px;text-transform:uppercase;margin-top:6px;}
.tpl-elegant .r-contact{font-size:11px;color:#666;margin-top:12px;font-family:'Inter',sans-serif;}
.tpl-elegant .r-rule{width:90px;height:2px;background:var(--r-accent);margin:18px auto 24px;}
.tpl-elegant .sec-title{text-align:left;font-family:var(--r-font-display);font-weight:600;letter-spacing:2px;border-bottom:1px solid #ddd;padding-bottom:6px;color:var(--r-ink);}
.tpl-elegant .item{text-align:left;}
.tpl-elegant .skill-pill{display:inline-block;font-size:11.5px;color:#444;margin:0 10px 6px 0;font-family:'Inter',sans-serif;}
.tpl-elegant .skill-pill:not(:last-child)::after{content:'·';margin-left:10px;color:var(--r-accent);}

/* SIDEBAR */
.tpl-sidebar{display:flex;font-family:var(--r-font-body);min-height:1123px;}
.tpl-sidebar .side{width:270px;background:var(--r-ink);color:#fff;padding:42px 26px;}
.tpl-sidebar .side .r-name{font-size:22px;font-weight:600;line-height:1.25;font-family:var(--r-font-display);}
.tpl-sidebar .side .r-title{font-size:12px;color:var(--r-accent);font-weight:500;margin-top:6px;}
.tpl-sidebar .side .side-sec{margin-top:30px;}
.tpl-sidebar .side .side-sec-title{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--r-accent);margin-bottom:10px;font-weight:600;}
.tpl-sidebar .side .contact-line{font-size:11px;color:#CBD1E0;margin-bottom:7px;word-break:break-word;}
.tpl-sidebar .side .skill-pill{display:block;font-size:11.5px;color:#EDEFF5;margin-bottom:7px;position:relative;padding-left:12px;}
.tpl-sidebar .side .skill-pill::before{content:'';position:absolute;left:0;top:5px;width:5px;height:5px;background:var(--r-accent);border-radius:50%;}
.tpl-sidebar .main{flex:1;padding:42px 36px;font-family:'Inter',sans-serif;}
.tpl-sidebar .main .sec-title{color:var(--r-ink);border-bottom:2px solid var(--r-soft);padding-bottom:6px;}

/* CREATIVE */
.tpl-creative{font-family:var(--r-font-body);}
.tpl-creative .r-band{background:linear-gradient(120deg,var(--r-accent),var(--r-accent-b,var(--r-accent)));padding:40px 50px;color:#fff;}
.tpl-creative .r-name{font-size:28px;font-weight:700;}
.tpl-creative .r-title{font-size:13px;font-weight:500;margin-top:4px;opacity:0.95;}
.tpl-creative .r-contact{display:flex;flex-wrap:wrap;gap:14px;font-size:11px;margin-top:14px;opacity:0.95;}
.tpl-creative .r-body{padding:34px 50px;}
.tpl-creative .sec-title{color:var(--r-accent);}
.tpl-creative .skill-pill{display:inline-block;background:var(--r-soft);color:var(--r-ink);font-size:11.5px;font-weight:600;padding:6px 12px;border-radius:16px;margin:0 6px 6px 0;}

/* ATS */
.tpl-ats{padding:44px 54px;font-family:var(--r-font-body);color:#000;}
.tpl-ats .r-name{font-size:22px;font-weight:700;}
.tpl-ats .r-title{font-size:13px;margin-top:2px;}
.tpl-ats .r-contact{font-size:11.5px;margin-top:8px;color:#222;}
.tpl-ats .r-rule{border-top:1px solid #000;margin:14px 0 18px;}
.tpl-ats .sec-title{color:#000;border-bottom:1px solid #000;padding-bottom:3px;}
.tpl-ats .skill-pill{display:inline;font-size:12px;}
.tpl-ats .skill-pill:not(:last-child)::after{content:', ';}

/* TIMELINE */
.tpl-timeline{padding:46px 50px;font-family:var(--r-font-body);}
.tpl-timeline .r-head{border-bottom:2px solid var(--r-soft);padding-bottom:16px;margin-bottom:22px;}
.tpl-timeline .r-name{font-size:28px;font-weight:700;color:var(--r-ink);font-family:var(--r-font-display);}
.tpl-timeline .r-title{font-size:13px;color:var(--r-accent);font-weight:600;margin-top:3px;}
.tpl-timeline .r-contact{display:flex;flex-wrap:wrap;gap:12px;font-size:11.5px;color:#555;margin-top:10px;}
.tpl-timeline .sec-title{color:var(--r-ink);}
.tpl-timeline .skill-pill{display:inline-block;background:var(--r-soft);color:var(--r-ink);font-size:11.5px;font-weight:600;padding:5px 11px;border-radius:5px;margin:0 6px 6px 0;}
.tpl-timeline .item{position:relative;padding-left:20px;margin-left:4px;padding-bottom:2px;border-left:2px solid var(--r-soft);}
.tpl-timeline .item::before{content:'';position:absolute;left:-6px;top:2px;width:10px;height:10px;border-radius:50%;background:var(--r-accent);border:2px solid #fff;box-shadow:0 0 0 1px var(--r-accent);}
.tpl-timeline .item:last-child{border-left:2px solid transparent;}

/* COMPACT */
.tpl-compact{padding:0;font-family:var(--r-font-body);}
.tpl-compact .c-header{display:flex;align-items:center;gap:18px;padding:40px 46px 24px;border-bottom:2px solid var(--r-soft);}
.tpl-compact .c-avatar{width:64px;height:64px;border-radius:50%;background:var(--r-accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;font-family:var(--r-font-display);flex-shrink:0;}
.tpl-compact .r-name{font-size:24px;font-weight:700;color:var(--r-ink);font-family:var(--r-font-display);}
.tpl-compact .r-title{font-size:13px;color:var(--r-accent);font-weight:600;margin-top:3px;}
.tpl-compact .c-body{display:flex;padding:28px 46px 40px;gap:34px;}
.tpl-compact .c-main{flex:1;min-width:0;}
.tpl-compact .c-main .sec-title{color:var(--r-ink);border-bottom:2px solid var(--r-soft);padding-bottom:5px;}
.tpl-compact .c-aside{width:200px;flex-shrink:0;}
.tpl-compact .c-aside .sec-title{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--r-ink);margin-bottom:8px;}
.tpl-compact .aside-line{font-size:11.5px;color:#555;margin-bottom:6px;word-break:break-word;}
