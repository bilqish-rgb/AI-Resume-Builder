/* ============ SCALING ============ */
function fitScale(){
  const stage = document.querySelector('.preview-stage');
  const scaler = document.getElementById('previewScaler');
  const inner = document.getElementById('previewInner');
  if(!stage || !inner) return;
  const availWidth = stage.clientWidth;
  const scale = Math.min(1, (availWidth - 4) / 794);
  scaler.style.transform = `scale(${scale})`;
  scaler.style.width = '794px';
  stage.style.height = (inner.scrollHeight * scale) + 'px';
}
window.addEventListener('resize', fitScale);

/* ============ EVENT HANDLING ============ */
document.getElementById('tabs').addEventListener('click', (e) => {
  const btn = e.target.closest('[data-tab]');
  if(!btn) return;
  state.activeTab = btn.getAttribute('data-tab');
  renderTabs();
  renderForm();
});

document.getElementById('formPanel').addEventListener('click', (e) => {
  const tplCard = e.target.closest('[data-select-template]');
  if(tplCard){
    state.template = tplCard.getAttribute('data-select-template');
    renderForm();
    renderPreview();
    return;
  }
  const aiBtn = e.target.closest('[data-ai]');
  if(aiBtn){ handleAiClick(aiBtn); return; }

  const addBtn = e.target.closest('[data-add]');
  if(addBtn){
    const type = addBtn.getAttribute('data-add');
    if(type==='experience') state.experience.push({id:newId(),position:'',company:'',location:'',start:'',end:'',current:false,description:''});
    if(type==='education') state.education.push({id:newId(),degree:'',school:'',location:'',start:'',end:'',description:''});
    if(type==='languages') state.languages.push({id:newId(),name:'',level:'Menengah'});
    if(type==='certifications') state.certifications.push({id:newId(),name:'',issuer:'',year:''});
    renderForm();
    renderPreview();
    return;
  }
  const removeBtn = e.target.closest('[data-remove]');
  if(removeBtn){
    const type = removeBtn.getAttribute('data-remove');
    const idx = parseInt(removeBtn.getAttribute('data-idx'),10);
    state[type].splice(idx,1);
    renderForm();
    renderPreview();
    return;
  }
  const removeSkill = e.target.closest('[data-remove-skill]');
  if(removeSkill){
    const idx = parseInt(removeSkill.getAttribute('data-remove-skill'),10);
    state.skills.splice(idx,1);
    renderForm();
    renderPreview();
    return;
  }
  const addSkillBtn = e.target.closest('#addSkillBtn');
  if(addSkillBtn){
    commitSkillInput();
    return;
  }
});

document.getElementById('formPanel').addEventListener('keydown', (e) => {
  if(e.target && e.target.id === 'skillInput' && e.key === 'Enter'){
    e.preventDefault();
    commitSkillInput();
  }
});
function commitSkillInput(){
  const input = document.getElementById('skillInput');
  if(!input) return;
  const val = input.value.trim();
  if(val){
    state.skills.push(val);
    renderForm();
    renderPreview();
    const newInput = document.getElementById('skillInput');
    if(newInput) newInput.focus();
  }
}

document.getElementById('formPanel').addEventListener('input', (e) => {
  const bindEl = e.target.closest('[data-bind]');
  if(bindEl){
    const path = bindEl.getAttribute('data-bind').split('.');
    state[path[0]][path[1]] = bindEl.value;
    renderPreview();
    return;
  }
  const arrEl = e.target.closest('[data-arr]');
  if(arrEl){
    const type = arrEl.getAttribute('data-arr');
    const idx = parseInt(arrEl.getAttribute('data-idx'),10);
    const field = arrEl.getAttribute('data-field');
    const value = arrEl.type === 'checkbox' ? arrEl.checked : arrEl.value;
    state[type][idx][field] = value;
    if(type==='experience' && field==='current'){
      renderForm();
    }
    renderPreview();
  }
});

