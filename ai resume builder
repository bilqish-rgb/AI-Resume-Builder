/* ============ PDF EXPORT ============ */
document.getElementById('downloadBtn').addEventListener('click', async () => {
  const btn = document.getElementById('downloadBtn');
  const original = btn.textContent;
  btn.disabled = true;
  btn.textContent = 'Membuat PDF…';
  try{
    const source = document.getElementById('previewInner');
    const canvas = await html2canvas(source, {scale:2, useCORS:true, backgroundColor:'#ffffff'});
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF('p','mm','a4');
    const pageWidth = 210;
    const pageHeight = 297;
    const imgWidth = pageWidth;
    const imgHeight = canvas.height * imgWidth / canvas.width;
    const imgData = canvas.toDataURL('image/png');
    let heightLeft = imgHeight;
    let position = 0;
    pdf.addImage(imgData,'PNG',0,position,imgWidth,imgHeight);
    heightLeft -= pageHeight;
    while(heightLeft > 0){
      position = heightLeft - imgHeight;
      pdf.addPage();
      pdf.addImage(imgData,'PNG',0,position,imgWidth,imgHeight);
      heightLeft -= pageHeight;
    }
    const fileName = (state.personal.name || 'CV').trim().replace(/\s+/g,'_');
    pdf.save(`CV_${fileName}.pdf`);
  }catch(err){
    console.error(err);
    alert('Gagal membuat PDF. Coba lagi.');
  }finally{
    btn.disabled = false;
    btn.textContent = original;
  }
});

