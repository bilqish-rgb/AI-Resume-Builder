}

function thumbMarkup(skeleton, theme){
  const accent = theme.accent || '#B4802B';
  const ink = theme.ink || '#14213D';
  const accentB = theme.accentB || accent;
  const soft = theme.soft || '#EEEEEE';
  if(skeleton==='modern') return `<div class="thumb-modern"><div class="l1" style="background:${ink}"></div><div class="l2" style="background:${accent}"></div><div class="l3"></div><div class="l3b"></div></div>`;
  if(skeleton==='elegant') return `<div class="thumb-elegant"><div class="l1" style="background:${ink}"></div><div class="rule" style="background:${accent}"></div><div class="l3"></div><div class="l3b"></div></div>`;
  if(skeleton==='sidebar') return `<div class="thumb-sidebar"><div class="side" style="background:${ink}"></div><div class="main"><div class="l1"></div><div class="l3"></div><div class="l3b"></div></div></div>`;
  if(skeleton==='creative') return `<div class="thumb-creative"><div class="band" style="background:linear-gradient(90deg,${accent},${accentB})"></div><div class="body"><div class="l3"></div><span class="pill" style="background:${soft}"></span><span class="pill" style="background:${soft}"></span></div></div>`;
  if(skeleton==='ats') return `<div class="thumb-ats"><div class="l1"></div><div class="l3"></div><div class="l3b"></div></div>`;
  if(skeleton==='timeline') return `<div class="thumb-timeline"><div class="tl-head" style="background:${ink}"></div><div class="tl-item"><span class="tl-dot" style="background:${accent}"></span><span class="tl-line"></span></div><div class="tl-item"><span class="tl-dot" style="background:${accent}"></span><span class="tl-line"></span></div></div>`;
  if(skeleton==='compact') return `<div class="thumb-compact"><div class="cp-head"><span class="cp-avatar" style="background:${accent}"></span><div class="cp-lines"><div class="l1" style="background:${ink}"></div><div class="l2b"></div></div></div><div class="cp-body"><div class="cp-main"></div><div class="cp-aside" style="background:${soft}"></div></div></div>`;
  return '';
}

